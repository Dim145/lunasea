{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", ".git"],
  "include": ["src/**/*"],
  "lib": ["ES2022"]
}
