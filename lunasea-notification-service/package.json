{
  "name": "lunasea-notification-service",
  "version": "1.5.5",
  "description": "Notification service for LunaSea",
  "repository": "https://github.com/JagandeepBrar/LunaSea-Notification-Service",
  "main": "dist/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon --config nodemon.json src/index.ts",
    "start:dev": "cross-env NODE_ENV=development nodemon --config nodemon.json src/index.ts | pino-pretty -c -t -l",
    "build": "tsc",
    "serve": "cross-env NODE_ENV=production node -r dotenv/config dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "author": "Jagandeep Brar",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lru-cache": "^11.5.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
