# Required
NTFY_BASE_URL=https://ntfy.example.com
FANART_TV_API_KEY=
THEMOVIEDB_API_KEY=

# Optional auth for publishing to ntfy. Choose ONE of the two methods below.
# 1) Access token (Bearer). Takes priority if both are set.
NTFY_TOKEN=
# 2) Basic auth (username/password). Used only if NTFY_TOKEN is empty.
NTFY_USERNAME=
NTFY_PASSWORD=

# Optional: defense-in-depth on the webhook ingress.
# When set, incoming Sonarr/Radarr/etc. webhooks must carry
# `Authorization: Bearer <WEBHOOK_TOKEN>` or they are rejected.
WEBHOOK_TOKEN=

# Optional: HTTP port the service binds to
PORT=9000
