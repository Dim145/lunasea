# Required
NTFY_BASE_URL=https://ntfy.example.com
FANART_TV_API_KEY=
THEMOVIEDB_API_KEY=

# Optional: Bearer token for publishing to ntfy (set if your ntfy server has auth on write)
NTFY_TOKEN=

# Optional: defense-in-depth on the webhook ingress.
# When set, incoming Sonarr/Radarr/etc. webhooks must carry
# `Authorization: Bearer <WEBHOOK_TOKEN>` or they are rejected.
WEBHOOK_TOKEN=

# Optional: HTTP port the service binds to
PORT=9000
