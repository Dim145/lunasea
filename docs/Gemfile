source 'https://rubygems.org'

# GitHub Pages uses this gem to mirror the exact stack run on their servers.
# Locally: `cd docs && bundle install && bundle exec jekyll serve`.
gem 'github-pages', group: :jekyll_plugins

# Just the Docs is consumed via `remote_theme:` in _config.yml — no gem
# entry is needed for it. The remote-theme plugin handles the fetch.

group :jekyll_plugins do
  gem 'jekyll-remote-theme'
  gem 'jekyll-relative-links'
  gem 'jekyll-seo-tag'
end

# Windows/JRuby support (harmless on other platforms).
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem 'tzinfo', '>= 1', '< 3'
  gem 'tzinfo-data'
end
